# Supabase Self-Hosted — Environment Variables Template
# Copy this file to .env and fill in your values.
# Generate secrets with: openssl rand -base64 32

############
# Required #
############

# JWT secret — must match across all services
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
POSTGRES_PASSWORD=your-super-secret-password
JWT_SECRET=your-jwt-secret-at-least-32-chars
ANON_KEY=your-supabase-anon-key
SERVICE_ROLE_KEY=your-supabase-service-role-key

# Dashboard credentials
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=your-dashboard-password

############
# URLs     #
############

SITE_URL=https://terminia.pezserv.org
API_EXTERNAL_URL=https://supabase-terminia.pezserv.org
SUPABASE_PUBLIC_URL=https://supabase-terminia.pezserv.org
SUPABASE_HOST=supabase-terminia.pezserv.org

############
# Ports    #
############

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
POSTGRES_PORT=5432
POOLER_PROXY_PORT_TRANSACTION=6543

############
# Postgres #
############

POSTGRES_HOST=db
POSTGRES_DB=postgres

############
# Studio   #
############

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project

############
# Auth     #
############

JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
ADDITIONAL_REDIRECT_URLS=

# Mailer URL paths
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

############
# SMTP     #
############

SMTP_ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Terminia

############
# REST     #
############

PGRST_DB_SCHEMAS=public,storage,graphql_public

############
# Realtime / Supavisor #
############

SECRET_KEY_BASE=your-secret-key-base-at-least-64-chars
VAULT_ENC_KEY=your-vault-encryption-key

############
# Pooler   #
############

POOLER_TENANT_ID=default-tenant
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100

############
# Edge Functions #
############

FUNCTIONS_VERIFY_JWT=true

############
# Storage  #
############

IMGPROXY_ENABLE_WEBP_DETECTION=true

############
# Analytics #
############

LOGFLARE_API_KEY=your-logflare-key

# Google (optional, for BigQuery analytics backend)
# GOOGLE_PROJECT_ID=
# GOOGLE_PROJECT_NUMBER=

############
# Vector   #
############

DOCKER_SOCKET_LOCATION=/var/run/docker.sock

############
# Container prefix (used for naming) #
############

CONTAINER_PREFIX=supabase
