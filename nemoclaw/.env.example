# NemoClaw Environment Variables

# Domain for external access via Cloudflare tunnel
DOMAIN=nemoclaw.pezserv.org

# OpenShell Gateway (container internal port)
OPENSHELL_GATEWAY=terminia-gateway
OPENSHELL_PORT=30051

# Inference provider (litellm-proxy on ai-network)
INFERENCE_PROVIDER=litellm
INFERENCE_ENDPOINT=http://litellm-proxy:4000
INFERENCE_MODEL=nemotron-orchestrator

# Cloudflare Tunnel (if exposing externally)
# Add route: nemoclaw.pezserv.org → http://openshell-gateway:30051
CLOUDFLARE_TUNNEL_ROUTE=nemoclaw.pezserv.org

# Traefik (Dokploy routing)
TRAEFIK_NETWORK=dokploy-network
TRAEFIK_ENTRYPOINT_HTTPS=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
