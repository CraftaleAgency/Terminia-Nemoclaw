# NemoClaw — Environment Template
# Copy to .env and fill in your values:  cp .env.example .env

# OpenShell Gateway
OPENSHELL_GATEWAY=terminia-gateway
OPENSHELL_PORT=30051
GATEWAY_HOST_PORT=8082

# Inference provider (litellm-proxy on ai-network)
INFERENCE_PROVIDER=litellm
INFERENCE_ENDPOINT=http://litellm-proxy:4000
INFERENCE_MODEL=nemotron-orchestrator

# External access (Cloudflare tunnel)
DOMAIN=your-domain.example.com
CLOUDFLARE_TUNNEL_ROUTE=your-domain.example.com

# Dokploy routing
TRAEFIK_NETWORK=dokploy-network

# Telegram bot bridge
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Terminia API
API_HOST_PORT=3100
CORS_ORIGINS=http://localhost:3000,https://terminia.pezserv.org,https://terminia.it

# Supabase (self-hosted via Dokploy)
SUPABASE_URL=https://supabase-terminia.pezserv.org
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
