# Nebula AI Services — Environment Template
# Copy to .env and fill in your values:  cp .env.example .env

# Model paths (host directories mounted read-only into containers)
ORCHESTRATOR_MODEL_PATH=/path/to/models/nemotron-orchestrator
ORCHESTRATOR_MODEL_FILE=orchestrator-8b-claude-4.5-opus-distill.q4_k_m.gguf
ORCHESTRATOR_CTX_SIZE=32768
ORCHESTRATOR_THREADS=24
ORCHESTRATOR_MEMORY_LIMIT=10G
ORCHESTRATOR_PORT=8083
ORCHESTRATOR_REASONING_BUDGET=1024

WORKER_MODEL_PATH=/path/to/models/nemotron-nano-worker
WORKER_MODEL_FILE=NVIDIA-Nemotron3-Nano-4B-Q4_K_M.gguf
WORKER_CTX_SIZE=16384
WORKER_THREADS=16
WORKER_MEMORY_LIMIT=6G
WORKER_PORT=8084
WORKER_REASONING_BUDGET=512

# LiteLLM Proxy
LITELLM_PORT=4000
LITELLM_DROP_PARAMS=true
LITELLM_MEMORY_LIMIT=2G

# Vision - Nemotron-Nano-VL-8B
# Download from: https://huggingface.co/nvidia/Llama-3.1-Nemotron-Nano-VL-8B-V1
VISION_MODEL_PATH=/path/to/models/nemotron-vl
VISION_MODEL_FILE=Llama-3.1-Nemotron-Nano-VL-8B-V1-Q4_K_M.gguf
VISION_MMPROJ_FILE=Llama-3.1-Nemotron-Nano-VL-8B-V1-mmproj-f16.gguf
VISION_CTX_SIZE=8192
VISION_THREADS=16
VISION_MEMORY_LIMIT=12G
VISION_PORT=8085
